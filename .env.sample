# =============================================================================
# UNIFIED MCP SERVER — Environment Configuration
# Copia este archivo a .env y completa tus credenciales
# =============================================================================

# ─── CHATEA PRO (requerido) ───
# Obtén tu token en: https://chateapro.app → Workspace Settings
CHATEAPRO_API_TOKEN=your-api-token-here

# Opcional: URL personalizada de la API
# CHATEAPRO_API_URL=https://chateapro.app/api

# ─── BRAVE SEARCH (opcional — si no se configura, las tools de Brave se ocultan) ───
# Obtén tu key en: https://brave.com/search/api/
# BRAVE_API_KEY=your-brave-api-key-here

# ─── DROPI (MCP externo, ya sincronizado) ───
# Dropi tiene su propio MCP server. Estas variables son para
# las tools de integración Dropi dentro de ChateaPro.
# DROPI_STORE_ID=your-dropi-store-id
# DROPI_API_KEY=your-dropi-api-key

# ─── SHOPIFY (opcional) ───
# SHOPIFY_STORE_URL=your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=your-shopify-access-token

# ─── NODE ───
# NODE_ENV=development
