# CMP ChateaPro — MCP Server Unificado
# Copia este archivo a .env y completa tus credenciales

# Obligatorio — Token de ChateaPro
# Obtenlo en: https://chateapro.app → Workspace Settings
CHATEAPRO_API_TOKEN=your-api-token-here

# Opcional — API Key de Brave Search
# Obtenla en: https://brave.com/search/api/
# Si no se configura, las 8 tools de Brave se ocultan
# BRAVE_API_KEY=your-brave-api-key-here
