# Chatea Pro MCP Server - Environment Configuration
# Copy this file to .env and fill in your credentials

# Required: Chatea Pro API Token
# Get your token from: https://chateapro.app (Workspace Settings)
CHATEAPRO_API_TOKEN=your-api-token-here

# Optional: Chatea Pro API Base URL
# Default: https://chateapro.app/api
# Use this only if you have a custom instance URL
CHATEAPRO_API_URL=https://chateapro.app/api

# Optional: Dropi Integration
# Store/Account ID in Dropi (e.g., 915488)
# Get this from: Dropi Dashboard > Account Settings
DROPI_STORE_ID=

# Optional: Dropi API Key
# Get this from: Dropi Dashboard > API Credentials
DROPI_API_KEY=

# Optional: Shopify Integration
# Your Shopify store URL (e.g., mystore.myshopify.com)
SHOPIFY_STORE_URL=

# Optional: Shopify Access Token
# Generate from: Shopify Admin > Apps and integrations > Develop apps
SHOPIFY_ACCESS_TOKEN=

# Optional: Node Environment
NODE_ENV=development
