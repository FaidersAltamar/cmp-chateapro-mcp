# Brave Search API Key (required)
# Get your key at: https://api-dashboard.search.brave.com/app/keys
BRAVE_API_KEY=your_api_key_here

# Transport mode ("http" or "stdio", default: "stdio")
# BRAVE_MCP_TRANSPORT=stdio

# HTTP server port (default: 8080)
# BRAVE_MCP_PORT=8080

# HTTP server host (default: "0.0.0.0")
# BRAVE_MCP_HOST=0.0.0.0

# Logging level: debug, info, notice, warning, error, critical, alert, emergency (default: info)
# BRAVE_MCP_LOG_LEVEL=info

# Space-separated whitelist of enabled tools
# BRAVE_MCP_ENABLED_TOOLS=

# Space-separated blacklist of tools to disable
# BRAVE_MCP_DISABLED_TOOLS=

# HTTP stateless mode (default: "true")
# BRAVE_MCP_STATELESS=true
